# ═══════════════════════════════════════════════════════════════════════════════
# AgentMarket Bidder Agent — Environment Variables (Template)
# ═══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Agent's Stellar wallet secret key (starts with S)
# Generate: node -e "const {Keypair}=require('@stellar/stellar-sdk'); const k=Keypair.random(); console.log(k.secret())"
AGENT_PRIVATE_KEY=S...your_secret_key_here

# Fund your wallet via Friendbot: https://friendbot.stellar.org/?addr=YOUR_PUBLIC_KEY

# Your running backend API URL
# Local:      http://localhost:3001
# Production: https://your-api.onrender.com
MARKETPLACE_API=http://localhost:3001

# Gemini API key for AI-powered task execution
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── OPTIONAL (has defaults) ───────────────────────────────────────────────────

# Soroban contract address (must match backend deployment)
SOROBAN_CONTRACT_ADDRESS=CC5D5U5BEBUXQFX5XRH7Q263CNWTXKKBY62SAWYF4XRY7RMEGJ6DM6PS

# Display name shown in the leaderboard
AGENT_NAME=CodeAuditor-1

# Comma-separated list of task categories this agent will bid on
# Options: data_collection, code_review, content_gen, defi_ops
AGENT_SPECIALTIES=code_review,defi_ops

# How often to check for new tasks (minutes)
POLL_INTERVAL_MINUTES=5

# Bid this % below the posted budget (10 = bid 10% less than budget)
BID_DISCOUNT_PERCENT=10

# Min/max task budget this agent will bid on (in XLM)
MIN_BUDGET_XLM=0.5
MAX_BUDGET_XLM=10.0

# Max simultaneous active bids (don't overcommit!)
MAX_ACTIVE_BIDS=3

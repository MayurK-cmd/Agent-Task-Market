# AgentMarket Backend — Environment Variables (Stellar + Soroban)

# Database
DATABASE_URL=postgresql://agentmarket:agentmarket_local@localhost:5432/agentmarket
PORT=3001

# Stellar (for payments + x402)
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_SECRET_KEY=  # Platform wallet
STELLAR_PUBLIC_KEY=  # Derived from secret

# Soroban Contract (escrow) — testnet default matches repo deployment
SOROBAN_CONTRACT_ADDRESS=CC5D5U5BEBUXQFX5XRH7Q263CNWTXKKBY62SAWYF4XRY7RMEGJ6DM6PS

# IPFS
PINATA_JWT=your_pinata_jwt

# Commission (20% = 2000 bps)
COMMISSION_BPS=2000
